#include "sort.h"
#include <stdio.h>

/**
 * insertion_sort_list - Sorts a doubly linked list in ascending order
 * using the Insertion sort algorithm.
 * @list: A pointer to the pointer to the head of the doubly linked list.
 */
void insertion_sort_list(listint_t **list)
{
    listint_t *current, *temp, *node;

    if (list == NULL || *list == NULL || (*list)->next == NULL)
        return;

    current = (*list)->next;

    while (current != NULL)
    {
        node = current;
        while (node->prev != NULL && node->n < node->prev->n)
        {
            temp = node->prev;
            node->prev = temp->prev;
            if (temp->prev != NULL)
                temp->prev->next = node;
            else
                *list = node;

            temp->next = node->next;
            if (node->next != NULL)
                node->next->prev = temp;

            node->next = temp;
            temp->prev = node;

            print_list(*list);
        }
        current = current->next;
    }
}

